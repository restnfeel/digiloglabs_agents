{
  "name": "digiloglabs-agents-desktop",
  "version": "0.1.0",
  "private": false,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "tsc -p electron && electron .",
    "build:electron": "tsc -p electron",
    "build": "npm run build:electron && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:win:clean": "npm run build:electron && electron-builder --win -c electron-builder.clean.json",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "keytar": "^7.9.0",
    "electron-updater": "^6.1.7"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.5.0"
  },
  "build": {
    "appId": "com.digiloglabs.agents",
    "productName": "DigiLog Labs Agents",
    "copyright": "Copyright © 2026 DigiLog Labs Inc.",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "electron/dist/**",
      "fallback/**",
      "resources/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "zip"
      ]
    },
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": {
      "provider": "github"
    },
    "protocols": {
      "name": "digiloglabs-agents",
      "schemes": [
        "digiloglabs-agents"
      ]
    }
  },
  "description": "DigiLog Labs Agents desktop app",
  "author": "DigiLog Labs Inc. <contact@digiloglabs.com>"
}